//--------------------------------------------------------------
// 모니터링 서버 옵션 (서버->모니터링 서버는 인코딩 안씀)
//--------------------------------------------------------------
MONITOR_SERVER
{
	/* 인코딩 사용 여부 (1 사용 / 0 미사용) */
	bUseEncode = 1
	
	/* TCP 센드 버퍼 끄기 (1 끄기 / 0 켜기) */
	bUseSO_SNDBUF = 1

	/* TCP NODELAY 끄기 (1 끄기 / 0 켜기) */
	bUseTCP_NODELAY = 0

	/* 최대 서버 세션 수 (일단 서버는 3고정) */
	serveriMaxConcurrentUsers = 8

	/* 최대 클라 세션 수 */
	clientiMaxConcurrentUsers = 10

	/* 최대 클라 연결 수  */
	clientiMaxUsers = 8
	
	/* 서버 워커스레드 생성 수 */
	serveriWorkerThreadCreateCnt = 3
	
	/* 서버 워커스레드 러닝 수 */
	serveriWorkerThreadRunCnt = 2

	/* 클라 워커스레드 생성 수 */
	clientiWorkerThreadCreateCnt = 3
	
	/* 클라 워커스레드 러닝 수 */
	clientiWorkerThreadRunCnt = 2

	/* 서버쪽 오픈ip */
	serverOpenIP = "0.0.0.0"

	/* 서버쪽 포트 */
	serverPort = 8000

	/* 모니터링 클라쪽 오픈ip */
	clientOpenIP = "0.0.0.0"

	/* 모니터링 클라쪽 포트 */
	clientPort = 9000

	/* 서버 패킷 코드 */
	serverCode = 109

	/* 서버 패킷 키 */
	staticKey = 30
}

