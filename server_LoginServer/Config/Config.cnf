//--------------------------------------------------------------
// 로그인 서버 옵션
//--------------------------------------------------------------
LOGIN_SERVER
{
	/* 인코딩 사용 여부 (1 사용 / 0 미사용) */
	bUseEncode = 1
	
	/* TCP 센드 버퍼 끄기 (1 끄기 / 0 켜기) */
	bUseSO_SNDBUF = 1

	/* TCP NODELAY 끄기 (1 끄기 / 0 켜기) */
	bUseTCP_NODELAY = 0

	/* 최대 세션 수(로그인 대기자 수) */
	iMaxConcurrentUsers = 20000

	/* 최대 유저 수(로그인 수) */
	iMaxUsers = 15000
	
	/* 워커스레드 생성 수 */
	iWorkerThreadCreateCnt = 10
	
	/* 워커스레드 러닝 수 */
	iWorkerThreadRunCnt = 8

	/* 오픈ip */
	openIP = "0.0.0.0"

	/* 포트 */
	port = 7000

	/* 게임서버ip */
	gameIP = "106.245.38.108"
	
	/* 게임서버port */
	gamePort = 6000

	/* 채팅서버ip */
	chatIP = "127.0.0.1"

	/* 채팅서버 더미ip 1*/
	dummyOne = "127.0.0.1"
	
	/* 채팅서버 더미ip 2*/
	dummyTwo = "127.0.0.1"

	/* 채팅서버 더미ip 3*/
	dummyThree = "127.0.0.1"

	/* 채팅서버port */
	chatPort = 6000

	/* 서버 패킷 코드 */
	serverCode = 119

	/* 서버 패킷 키 */
	staticKey = 50
}

